<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Scholarsafe - By Students, For Students</title>
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    html {
      scroll-behavior: smooth;
    }
  </style>
</head>

<body class="bg-white text-gray-900">

<!-- NAV -->
<header class="fixed w-full bg-white/80 backdrop-blur border-b z-50">
  <div class="max-w-6xl mx-auto flex justify-between items-center p-4">
    <h1 class="font-bold text-xl">Scholarsafe</h1>
    <nav class="space-x-6 text-sm">
      <a href="#problem">Problem</a>
      <a href="#solution">Solution</a>
      <a href="#features">Features</a>
      <a href="#how">How it Works</a>
    </nav>
  </div>
</header>

<!-- HERO -->
<section class="pt-32 pb-20 text-center bg-gradient-to-b from-blue-50 to-white">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-5xl font-bold leading-tight">
      Smarter Student Housing.<br/>Built <span class="text-blue-600">By Students, For Students.</span>
    </h2>

    <p class="mt-6 text-lg text-gray-600">
      Find safe, affordable, and compatible housing near campus using real student reviews,
      verified listings, and intelligent roommate matching.
    </p>

    <div class="mt-8 flex justify-center gap-4">
      <button class="bg-blue-600 text-white px-6 py-3 rounded-xl hover:bg-blue-700">
        Get Started
      </button>
      <button class="border px-6 py-3 rounded-xl">
        Browse Listings
      </button>
    </div>
  </div>
</section>

<!-- PROBLEM -->
<section id="problem" class="py-20 bg-gray-50">
  <div class="max-w-5xl mx-auto px-6">
    <h3 class="text-3xl font-bold mb-6">The Problem</h3>

    <p class="text-gray-700 leading-relaxed">
      Students are forced to choose housing based on price and location alone,
      without knowing what it’s actually like to live there. Listings are fragmented,
      reviews are unreliable, and roommate matching is disconnected from reality.
    </p>

    <div class="mt-6 grid md:grid-cols-3 gap-4 text-sm">
      <div class="bg-white p-4 rounded-xl shadow">No trusted student insights</div>
      <div class="bg-white p-4 rounded-xl shadow">No roommate compatibility tools</div>
      <div class="bg-white p-4 rounded-xl shadow">Limited safety/lifestyle context</div>
    </div>
  </div>
</section>

<!-- SOLUTION -->
<section id="solution" class="py-20">
  <div class="max-w-5xl mx-auto px-6">
    <h3 class="text-3xl font-bold mb-6">The Solution</h3>

    <p class="text-gray-700">
      Scholarsafe connects students to housing through verified listings,
      real student reviews, and smart compatibility matching—so students
      can make informed decisions with confidence.
    </p>

    <div class="mt-6 grid md:grid-cols-2 gap-6">
      <div class="p-6 border rounded-xl">
        <h4 class="font-semibold">Verified Student Listings</h4>
        <p class="text-sm text-gray-600 mt-2">Only real students contribute insights and reviews.</p>
      </div>

      <div class="p-6 border rounded-xl">
        <h4 class="font-semibold">Student Fit Score</h4>
        <p class="text-sm text-gray-600 mt-2">Match housing based on budget, lifestyle, and location.</p>
      </div>

      <div class="p-6 border rounded-xl">
        <h4 class="font-semibold">Roommate Matching</h4>
        <p class="text-sm text-gray-600 mt-2">Compatibility scoring for better living experiences.</p>
      </div>

      <div class="p-6 border rounded-xl">
        <h4 class="font-semibold">Real Student Reviews</h4>
        <p class="text-sm text-gray-600 mt-2">Noise, safety, landlord behavior, and daily experience.</p>
      </div>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section id="features" class="py-20 bg-gray-50">
  <div class="max-w-5xl mx-auto px-6">
    <h3 class="text-3xl font-bold mb-6">Key Features</h3>

    <ul class="space-y-4 text-gray-700">
      <li>🏠 Student-enhanced housing listings</li>
      <li>📊 Smart Student Fit Score system</li>
      <li>🤝 AI-based roommate compatibility matching</li>
      <li>🔒 .edu verified student community</li>
      <li>🗺️ Campus-based housing discovery map</li>
    </ul>
  </div>
</section>

<!-- HOW IT WORKS -->
<section id="how" class="py-20">
  <div class="max-w-5xl mx-auto px-6">
    <h3 class="text-3xl font-bold mb-6">How It Works</h3>

    <div class="grid md:grid-cols-4 gap-4 text-center text-sm">
      <div class="p-4 border rounded-xl">1. Discover housing near campus</div>
      <div class="p-4 border rounded-xl">2. Compare with Fit Score</div>
      <div class="p-4 border rounded-xl">3. Match with roommates</div>
      <div class="p-4 border rounded-xl">4. Secure your place</div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-20 bg-blue-600 text-white text-center">
  <h3 class="text-3xl font-bold">Make smarter housing decisions</h3>
  <p class="mt-3">Join Scholarsafe today.</p>

  <div class="mt-6">
    <button class="bg-white text-blue-600 px-6 py-3 rounded-xl font-semibold">
      Get Started
    </button>
  </div>
</section>

<!-- FOOTER -->
<footer class="py-8 text-center text-sm text-gray-500">
  © 2026 Scholarsafe — By Students, For Students
</footer>

</body>
</html>
